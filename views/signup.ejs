<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign Up - Smash Bros Coaching</title>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: 'Roboto', sans-serif;
            background: #ffffff;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            color: #000000;
        }
        @keyframes gradientShift {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }
        .signup-container {
            background: #ffffff;
            border: 2px solid #000000;
            padding: 40px;
            border-radius: 10px;
            width: 100%;
            max-width: 450px;
            border: 2px solid #000000;
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        }
        .logo {
            font-size: 2.5em;
            font-weight: 700;
            color: #000000;
            margin-bottom: 10px;
            text-align: center;
        }
        .subtitle {
            font-size: 1.1em;
            color: #000000;
            margin-bottom: 30px;
            text-align: center;
        }
        form {
            display: flex;
            flex-direction: column;
        }
        .input-group {
            position: relative;
            margin-bottom: 20px;
        }
        .input-group input,
        .input-group select {
            width: 100%;
            padding: 15px 20px;
            border: 2px solid #cccccc;
            border-radius: 5px;
            font-size: 16px;
            transition: border-color 0.3s ease;
            background: #ffffff;
            color: #000000;
        }
        .input-group input:focus,
        .input-group select:focus {
            border-color: #000000;
            outline: none;
        }
        .input-group label {
            position: absolute;
            top: 15px;
            left: 20px;
            color: #000000;
            transition: all 0.3s ease;
            pointer-events: none;
            background: #ffffff;
        }
        .input-group input:focus + label,
        .input-group input:not(:placeholder-shown) + label,
        .input-group select:focus + label {
            top: -10px;
            left: 15px;
            font-size: 12px;
            color: #000000;
            background: #ffffff;
            padding: 0 5px;
        }
        .checkbox-group {
            display: flex;
            align-items: center;
            margin-bottom: 20px;
        }
        .checkbox-group input[type="checkbox"] {
            width: auto;
            margin-right: 10px;
        }
        .checkbox-group label {
            font-size: 16px;
            color: #000000;
            cursor: pointer;
        }
        button {
            padding: 15px;
            background: #000000;
            color: #ffffff;
            border: 2px solid #000000;
            border-radius: 5px;
            font-size: 18px;
            font-weight: 600;
            cursor: pointer;
            transition: background-color 0.3s ease;
            margin-top: 10px;
        }
        button:hover {
            background: #ffffff;
            color: #000000;
        }
        .footer {
            margin-top: 20px;
            text-align: center;
            font-size: 14px;
            color: #000000;
        }
        .footer a {
            color: #000000;
            text-decoration: none;
            font-weight: 600;
        }
        .footer a:hover {
            text-decoration: underline;
        }
        .error {
            background: #ffcccc;
            color: #000000;
            padding: 10px;
            border-radius: 5px;
            margin-bottom: 20px;
            border: 1px solid #ff0000;
        }
    </style>
</head>
<body>
    <div class="signup-container">
        <div class="logo">🎮 Smash Bros</div>
        <div class="subtitle">Join the Coaching Community</div>
        <% if (typeof error !== 'undefined') { %>
            <div class="error"><%= error %></div>
        <% } %>
        <form action="/signup" method="POST">
            <div class="input-group">
                <input type="text" id="name" name="name" placeholder=" " required>
                <label for="name">Username</label>
            </div>
            <div class="input-group">
                <input type="password" id="password" name="password" placeholder=" " required>
                <label for="password">Password</label>
            </div>
            <div class="input-group">
                <input type="password" id="confirmPassword" name="confirmPassword" placeholder=" " required>
                <label for="confirmPassword">Confirm Password</label>
            </div>
            <div class="checkbox-group">
                <input type="checkbox" id="hasSwitch" name="hasSwitch">
                <label for="hasSwitch">I have a Nintendo Switch</label>
            </div>
            <div class="input-group">
                <select id="yearLevel" name="yearLevel" required>
                    <option value="">Select your year level</option>
                    <option value="9">9th Grade (Junior)</option>
                    <option value="10">10th Grade (Junior)</option>
                    <option value="11">11th Grade (Senior)</option>
                    <option value="12">12th Grade (Senior)</option>
                </select>
                <label for="yearLevel">Year Level in School</label>
            </div>
            <button type="submit">Create Account</button>
        </form>
        <div class="footer">
            Already have an account? <a href="/">Login here</a>
        </div>
    </div>
</body>
</html>
